{
  "tasks": {
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "out/**"]
    },
    "tanebi-milky#start": {
      "dependsOn": ["build"],
      "cache": false
    },
    "tanebi-milky#sea": {
      "dependsOn": ["lint", "build"],
      "outputs": ["sea/**"]
    }
  }
}
